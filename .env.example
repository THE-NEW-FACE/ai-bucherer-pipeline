# Copy this file to `.env` and fill in real keys.
# .env is gitignored — never commit it.
# On Streamlit Community Cloud, set these as Secrets instead (Settings → Secrets).

# ── Model APIs ──
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Dropbox storage ──
# Local/dev convenience: a short-lived access token (expires in ~4h).
DROPBOX_TOKEN=sl.u....
# Durable auth for cloud (preferred): OAuth app key/secret + a non-expiring refresh token.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
